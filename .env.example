# ==================== 站点基本信息 ====================
# 站点 URL（必需）
PUBLIC_SITE_URL=https://yourdomain.com

# 站点名称（必需）
PUBLIC_SITE_NAME="Your Site Name"

# 站点描述（必需）
PUBLIC_SITE_DESCRIPTION="Your site description"

# ==================== Algolia 搜索 ====================
# Algolia 应用 ID（启用搜索功能时必需）
ALGOLIA_APP_ID=your_app_id

# Algolia 搜索密钥（必需，前端使用）
ALGOLIA_SEARCH_KEY=your_search_key

# Algolia 索引名称（必需）
ALGOLIA_INDEX_NAME=your_index_name

# Algolia 管理员 API 密钥（仅用于上传搜索索引）
ALGOLIA_ADMIN_KEY=your_admin_key

# ==================== 播客功能（可选）====================
# 是否启用播客功能（true/false）
PUBLIC_PODCAST_ENABLED=false

# 播客音频文件的基础 URL（启用播客时必需）
# 例如：https://your-cdn.com/podcasts/
PUBLIC_PODCAST_AUDIO_BASE_URL=https://your-cdn.com/

# ==================== 评论系统（可选）====================
# Giscus 仓库（格式：username/repo）
PUBLIC_GISCUS_REPO=

# Giscus 仓库 ID
PUBLIC_GISCUS_REPO_ID=

# Giscus 分类
PUBLIC_GISCUS_CATEGORY=

# Giscus 分类 ID
PUBLIC_GISCUS_CATEGORY_ID=

# Giscus 主题（可选，默认为 light）
PUBLIC_GISCUS_THEME=light

# ==================== 社交媒体（可选）====================
# Twitter 用户名
PUBLIC_TWITTER_USERNAME=

# GitHub 用户名或仓库
PUBLIC_GITHUB_URL=

# Email 地址
PUBLIC_EMAIL=

# ==================== 构建相关 ====================
# 社交图片版本控制（用于缓存清除）
# 使用 'auto' 自动生成，或指定版本号
PUBLIC_SOCIAL_IMAGE_VERSION=auto

# 构建时间（自动设置，无需手动配置）
BUILD_TIME=$(date)
