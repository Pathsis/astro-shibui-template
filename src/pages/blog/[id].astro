---
import CoverLayout from "../../layouts/CoverLayout.astro";
import Sidebar from "../../components/Sidebar.astro";
import Giscus from "../../components/Giscus.astro";
import { PodcastPlayButton } from "../../components/PodcastPlayButton";
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLocalizedBlogPathById, getPairedTranslationIdByConvention } from "../../lib/post-url";
import { normalizeImagePath } from "../../lib/image-path";
import { getPodcastEpisodeSlug, getPodcastUrl } from "../../lib/podcast";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog-zh");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// 获取当前语言
const currentLang = Astro.currentLocale as "zh-cn" | "en" || "zh-cn";

// 检查是否有英文翻译版本（按命名约定自动匹配）
const enPosts = await getCollection("blog-en");
const expectedEnId = getPairedTranslationIdByConvention(post.id, "en");
const translation = expectedEnId
  ? enPosts.find((enPost) => enPost.id === expectedEnId)
  : undefined;
const hasTranslation = !!translation;

// 格式化日期
const formatDate = (date: Date) => {
  return date.toISOString().split("T")[0];
};

const toc = post.data.toc === true; // 只有显式设置 toc: true 时才显示

// 界面文本
const podcastHint = currentLang === "en" ? " (Podcast available)" : "（可收听播客）";
const tocText = currentLang === "en" ? "Table of Contents" : "目录";

// 获取封面图片：优先使用 frontmatter 中的 images，其次使用 image
let featuredImage: string | undefined;
let featuredImageSource: "images" | "other" = "other";
if (post.data.images && post.data.images.length > 0) {
  featuredImage = normalizeImagePath(post.data.images[0]);
  featuredImageSource = "images";
}
---

<CoverLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  pageKind="article"
  hasTranslation={hasTranslation}
  targetSlug={translation?.id}
  featuredImage={featuredImage}
  featuredImageSource={featuredImageSource}
  toc={toc}
>
  <Fragment slot="sidebar">
    <Sidebar
      tags={post.data.tags}
      toc={toc}
      currentSlug={post.id}
      lang={currentLang}
      related={post.data.related}
    />
  </Fragment>

  <article class="gh-content">
    <time datetime={post.data.date.toISOString()}>
      {formatDate(post.data.date)}
    </time>
    <h1 class={`article-title-heading ${post.data.podcast ? "has-podcast" : ""}`}>
      {post.data.title}
      {post.data.podcast && <span class="sr-only">{podcastHint}</span>}
      {post.data.podcast && (
        <PodcastPlayButton
          episode={{
            slug: getPodcastEpisodeSlug(post.id, "zh-cn"),
            title: post.data.title,
            url: getPodcastUrl(post.id, "zh-cn"),
            articleUrl: getRelativeLocaleUrl(currentLang, getLocalizedBlogPathById(post.id, currentLang)),
            date: post.data.date,
            lang: currentLang,
            description: post.data.description,
          }}
          client:load
        />
      )}
    </h1>

    {/* 目录（中小屏显示在元数据下方） */}
    {toc && (
      <div class="toc toc-inline">
        <div class="toc-title">{tocText}</div>
        <ul class="toc-list"></ul>
      </div>
    )}

    <Content />

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="terms-list article-tags">
        <ul>
          {post.data.tags.map((tag) => (
            <li>
              <a href={getRelativeLocaleUrl(currentLang, `/tags/${tag}/`)}>[{tag}]</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </article>

  {/* Giscus 评论 */}
  <Giscus lang={currentLang} />
</CoverLayout>

<style>
  /* 文章页特定样式 */
  .gh-content h1 {
    counter-increment: none;
  }
  .gh-content h1::before {
    content: none;
  }

  .gh-content {
    max-width: 100%;
  }

  .gh-content .article-title-heading {
    margin: var(--spacing-base) 0;
  }

  .gh-content .article-title-heading.has-podcast {
    position: relative;
    padding-right: 4.1em;
  }

  .gh-content .article-title-heading.has-podcast :global(.podcast-play-button) {
    position: absolute;
    top: 0.08em;
    right: 0;
    margin: 0;
    font-size: 0.92em;
  }

  .gh-content .article-tags {
    margin-top: var(--spacing-lg);
    padding-top: 0;
  }

  .gh-content .article-tags ul {
    margin: 0;
  }

  /* 标题锚点样式 */
  .heading-anchor {
    opacity: 0;
    margin-left: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  h2:hover .heading-anchor,
  h3:hover .heading-anchor,
  h4:hover .heading-anchor {
    opacity: 1;
  }

  .heading-anchor:focus {
    opacity: 1;
  }
</style>
