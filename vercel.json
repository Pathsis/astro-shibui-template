{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "TZ": "Asia/Shanghai"
    }
  },
  "buildCommand": "export BUILD_TIME=$(date +\"%Y/%m/%d %H:%M:%S\") && pnpm build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src *; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src *; object-src 'self'; media-src 'self'"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin"
        }
      ]
    }
  ]
}
